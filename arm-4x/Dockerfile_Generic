FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy The Pill engine
COPY orchestrator_generic.py .

# Create volume for investigation config and outputs
VOLUME ["/investigation"]

# Expose webhook port
EXPOSE 5000

# Entry point - user provides investigation_config.json in /investigation
CMD ["python", "orchestrator_generic.py", "/investigation/investigation_config.json"]
